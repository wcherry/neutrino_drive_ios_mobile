# xcodegen — project.yml is the source of truth; xcodeproj is regenerated via `xcodegen generate`
# Commit project.pbxproj so the project is immediately openable without running xcodegen
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

